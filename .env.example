# SayqalSMS configuration
SAYQAL_USERNAME=your_username
SAYQAL_TOKEN=your_token
SAYQAL_NICKNAME=your_nickname

# Firebase configuration (ikkalasidan birini tanlang)
# FIREBASE_CREDENTIALS={"type":"service_account","project_id":"..."}  # JSON string
# FIREBASE_CREDENTIALS_PATH=/usr/src/app/firebase-credentials.json    # fayl yo'li

# Celery / Redis
CELERY_BROKER_URL=redis://factory_redis:6379/0
CELERY_RESULT_BACKEND=redis://factory_redis:6379/0

# Database configuration
DATABASE_URL=postgresql://username:password@localhost:5432/dbname

# Django configuration
SECRET_KEY=your_secret_key
BASE_URL=http://localhost:8000
